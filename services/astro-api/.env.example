# ── Core ──────────────────────────────────────────────────────────────────────
# "production" enforces a real SECRET_KEY and disables auto create_all (run alembic upgrade head)
ENVIRONMENT=development
DATABASE_URL=sqlite+aiosqlite:///./astro.db
SECRET_KEY=change-me-in-production-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Directory for JPL ephemeris files (de440s.bsp auto-downloads on first run, ~32 MB)
SKYFIELD_DIR=./skyfield-data
# Optional: SPK file with 2060 Chiron (python scripts/fetch_chiron_spk.py)
CHIRON_SPK=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]
FRONTEND_URL=http://localhost:3000
# Publicly reachable URL of THIS backend (used for LiqPay server-side callback)
API_PUBLIC_URL=http://localhost:8000

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute

# ── Stripe (https://dashboard.stripe.com/apikeys) ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products + recurring prices in Stripe Dashboard and paste the price IDs:
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_EXPERT_MONTHLY=price_...

# ── LiqPay (https://www.liqpay.ua/api/information) ────────────────────────────
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
