# URL of the backend API (server-side fetches, not exposed to the browser)
API_URL=http://127.0.0.1:8000

# Canonical site URL used to build absolute links in robots.txt/sitemap.xml
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry (frontend). Empty = disabled (no-op).
NEXT_PUBLIC_SENTRY_DSN=

# Plausible Analytics (https://plausible.io) — cookie-less, no consent banner
# needed. Empty = disabled; no script is loaded and no requests are made.
# Set to your registered site domain (e.g. zorya.app) after adding it in
# the Plausible dashboard.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Feedback mailto link shown in the dashboard sidebar. Empty = not rendered.
NEXT_PUBLIC_FEEDBACK_EMAIL=
